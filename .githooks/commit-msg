#!/bin/sh
# 커밋 메시지 규칙 검사 (.cursor/rules/commit-convention.mdc 와 동일한 형식)
# 형식: <타입>(<범위>): <한글 제목>

MSG_FILE="$1"
SUBJECT=$(head -n1 "$MSG_FILE")

# merge, revert 등은 제목 형식 예외
if echo "$SUBJECT" | grep -qE '^Merge |^Revert '; then
  exit 0
fi

# 형식: 타입(범위): 제목  (타입만 있거나 타입(범위): 제목)
if ! echo "$SUBJECT" | grep -qE '^(feat|fix|docs|style|refactor|test|chore)(\([a-zA-Z0-9_-]+\))?: .+'; then
  echo "❌ 커밋 제목 형식 오류. 다음 형식을 사용하세요:" >&2
  echo "   <타입>(<범위>): <한글 제목>" >&2
  echo "   예: feat(ocr): OCR 정확도 개선을 위해 전처리 필터를 추가함" >&2
  echo "   타입: feat, fix, docs, style, refactor, test, chore" >&2
  exit 1
fi

# 제목 부분만 추출 (첫 번째 줄에서 ": " 이후)
TITLE_PART=$(echo "$SUBJECT" | sed 's/^[^:]*: *//')
# 한글이 포함되어 있는지 (제목이 한글이어야 함). UTF-8 가-힣
if ! echo "$TITLE_PART" | grep -qE '[가-힣]'; then
  echo "❌ 커밋 제목은 한글로 작성해야 합니다. (타입·범위·기술용어만 영문)" >&2
  echo "   현재 제목: $TITLE_PART" >&2
  exit 1
fi

# 50자 초과
if [ ${#SUBJECT} -gt 50 ]; then
  echo "❌ 커밋 제목은 50자 이내로 작성하세요. (현재 ${#SUBJECT}자)" >&2
  exit 1
fi

# 제목 끝 마침표 금지
if echo "$TITLE_PART" | grep -qE '\.$'; then
  echo "❌ 커밋 제목 끝에 마침표를 붙이지 마세요." >&2
  exit 1
fi

exit 0
